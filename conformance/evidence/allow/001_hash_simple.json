{
  "id": "evidence-hash-allow-001-simple",
  "description": "Valid hash evidence over invoice_001.txt upgrades matching untrusted provenance to trusted, allowing a money-impact proposal.",
  "source": "Adapted from examples/financial_hash_ok.json and tests/test_evidence_hash.py::test_evidence_hash_ok_verifies_and_upgrades_provenance.",
  "mode": "evidence",
  "expected": "allow",
  "options": {
    "verify_evidence": true,
    "evidence_root_dir": "conformance/artifacts",
    "strict_trust": true
  },
  "proposal": {
    "protocol": "PIC/1.0",
    "intent": "Send payment for approved invoice",
    "impact": "money",
    "provenance": [
      {
        "id": "invoice_001",
        "trust": "untrusted",
        "source": "file://invoice_001.txt"
      }
    ],
    "claims": [
      {
        "text": "Invoice #001 is approved for $500",
        "evidence": ["invoice_001"]
      }
    ],
    "action": {
      "tool": "payments_send",
      "args": { "amount": 500 }
    },
    "evidence": [
      {
        "id": "invoice_001",
        "type": "hash",
        "ref": "file://invoice_001.txt",
        "sha256": "a2e818612ae44f799be83833149cdd8a1ea750fa8d40bc8507f874f8ad488fbd"
      }
    ]
  }
}
