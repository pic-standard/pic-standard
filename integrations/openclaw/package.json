{
    "name": "pic-guard",
    "version": "0.8.1",
    "description": "PIC Standard governance plugin for OpenClaw",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint .",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "prepublishOnly": "npm run build"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "dist",
        "hooks",
        "config",
        "openclaw.plugin.json"
    ],
    "openclaw": {
        "extensions": [
            "./dist/index.js"
        ]
    },
    "keywords": [
        "pic",
        "provenance",
        "intent",
        "contracts",
        "openclaw",
        "plugin",
        "ai-safety",
        "tool-governance"
    ],
    "author": "Fabio Marcello Salvadori",
    "license": "Apache-2.0",
    "homepage": "https://github.com/pic-standard/pic-standard/tree/main/integrations/openclaw",
    "repository": {
        "type": "git",
        "url": "https://github.com/pic-standard/pic-standard.git",
        "directory": "integrations/openclaw"
    },
    "bugs": {
        "url": "https://github.com/pic-standard/pic-standard/issues"
    },
    "peerDependencies": {
        "openclaw": ">=2026.2.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/node": "^20.19.32",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.0.0",
        "vitest": "^4.0.0"
    }
}
